# Application
APP_ENV=development
APP_NAME=kepler-api
APP_VERSION=0.1.0
LOG_LEVEL=INFO
LOG_FORMAT=json

# HTTP
HTTP_HOST=0.0.0.0
HTTP_PORT=8000
HTTP_CORS_ORIGINS=http://localhost:3000
HTTP_TRUSTED_HOSTS=localhost,127.0.0.1

# Security
SECRET_KEY_BASE=change-me-in-production-min-32-chars
JWT_PRIVATE_KEY_PATH=./secrets/jwt_private.pem
JWT_PUBLIC_KEY_PATH=./secrets/jwt_public.pem
JWT_ISSUER=kepler.api
JWT_AUDIENCE_WEB=kepler.web
JWT_AUDIENCE_CLI=kepler.cli
JWT_AUDIENCE_API=kepler.api
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000
MFA_CHALLENGE_TTL_SECONDS=300

# Rate limiting
RATE_LIMIT_LOGIN_PER_EMAIL=5
RATE_LIMIT_LOGIN_WINDOW_SECONDS=900
RATE_LIMIT_LOGIN_LOCKOUT_SECONDS=900

# Database
DATABASE_URL=postgresql+asyncpg://kepler:kepler@localhost:5432/kepler
DATABASE_URL_SYNC=postgresql+psycopg2://kepler:kepler@localhost:5432/kepler
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_ECHO=false

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=20

# OpenTelemetry
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=kepler-api
